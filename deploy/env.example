# 复制为项目根目录 .env 后由 docker compose 读取
# cp deploy/env.example .env

# Nacos
NACOS_PORT=8848

# 对外端口
CHAT_GATEWAY_PORT=8080
CHAT_SERVICE_PORT=8081
CHAT_UI_PORT=80

# 模型（chat-service）
OPENAI_API_KEY=changeme
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini

# 智谱（可选）
ZHIPU_ENABLED=false
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4-flash
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# 无 Nacos 时可在 compose 中设置（需自行改 compose 或改用 scripts/start-local.sh）
# SPRING_PROFILES_ACTIVE=no-nacos
